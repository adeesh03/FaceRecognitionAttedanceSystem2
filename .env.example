HOST=0.0.0.0
PORT=5001

DB_HOST=localhost
DB_USER=attendance_app
DB_PASSWORD=replace-with-a-strong-database-password
DB_NAME=attendance_system

FLASK_SECRET_KEY=replace-with-output-from-python-secrets-token-hex
ADMIN_USERNAME=admin
# Prefer ADMIN_PASSWORD_HASH in production. Generate it with Werkzeug.
ADMIN_PASSWORD_HASH=replace-with-a-werkzeug-password-hash

# HTTPS is required for reliable mobile browser camera access.
PUBLIC_BASE_URL=https://attendance.example.com
COOKIE_SECURE=1
FACE_MATCH_TOLERANCE=0.5
INSTITUTION_NAME=JAIN University
APPLICATION_NAME=Smart Attendance Portal
